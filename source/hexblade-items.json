  {
    "_id": "hxbSpells0000001",
    "name": "Hexblade Patron Spells",
    "type": "feat",
    "img": "icons/magic/symbols/runes-star-pentagon-blue.webp",
    "system": {
      "description": {
        "value": "<h2>Hexblade Patron Spells</h2>\n<p>The magic of your patron ensures you always have certain spells ready. When you reach a Warlock level specified in the Hexblade Patron Spells table, you thereafter always have the listed spells prepared.</p>\n\n<table>\n  <thead>\n    <tr>\n      <th>Warlock Level</th>\n      <th>Spells</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <td>3</td>\n      <td><em>Shield</em>, <em>Wrathful Smite</em>, <em>Hex</em>, <em>Armor of Agathys</em></td>\n    </tr>\n    <tr>\n      <td>5</td>\n      <td><em>Spirit Shroud</em>, <em>Conjure Barrage</em></td>\n    </tr>\n    <tr>\n      <td>7</td>\n      <td><em>Staggering Smite</em>, <em>Shadow of Moil</em></td>\n    </tr>\n    <tr>\n      <td>9</td>\n      <td><em>Steel Wind Strike</em>, <em>Hold Monster</em></td>\n    </tr>\n  </tbody>\n</table>\n\n<p><strong>Foundry note:</strong> This feature is a formatted reference list only. It does not grant spell items automatically. Drag the spells from your installed PHB or rules compendium, or add a later macro that grants spells by UUID when the matching PHB spell compendium is available.</p>\n\n<p><strong>Design note:</strong> <em>Magic Weapon</em> was removed because a Pact Weapon is already magical for the intended Hexblade play pattern.</p>",
        "chat": ""
      },
      "source": {
        "custom": "Hexblade Patron Playtest",
        "rules": "2024",
        "revision": 1,
        "license": "Homebrew Playtest",
        "book": ""
      },
