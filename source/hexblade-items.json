  {
    "_id": "hxbPatron0000001",
    "name": "Hexblade Patron",
    "type": "subclass",
    "img": "icons/magic/unholy/orb-swirling-teal.webp",
    "system": {
      "description": {
        "value": "<h1>Hexblade Patron</h1>\n<p>Your pact binds you to a sentient curse, shadowed weapon, deathly patron, or hungry force that manifests through close combat. A Hexblade is not merely a spellcaster with a sword; you are a battlefield anchor, a living curse, and a shield against enemies that would pass you by.</p>\n<p>This subclass is designed for the 2024 Warlock chassis. It grants armor and shield training, a melee-only Pact Weapon mastery benefit, Hex Aura and Hex Charges, spectral battlefield support, and a level-14 Greater Hex choice.</p>",
        "chat": ""
      },
      "source": {
        "custom": "Hexblade Patron Playtest",
        "rules": "2024",
        "revision": 1,
        "license": "Homebrew Playtest",
        "book": ""
