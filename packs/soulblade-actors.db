d6)","img":"icons/magic/unholy/hand-claw-glow-orange.webp","appliedEffects":[],"enchant":{},"visibility":{"level":{"min":null,"max":null}}}},"identifier":"life-drain"},"effects":[],"flags":{},"sort":100000,"ownership":{"default":0},"_key":"!actors.items!hxbSpecterActor1.hxbLifeDrain0001"},{"_id":"hxbIncorporeal01","name":"Incorporeal Movement","type":"feat","img":"icons/magic/movement/trail-streak-zigzag-yellow.webp","system":{"description":{"value":"<p>The specter can move through creatures and objects as if they were Difficult Terrain. It takes 1d10 Force damage if it ends its turn inside an object.</p>","chat":""},"source":{"custom":"Soul Blade Patron","rules":"2024","revision":1,"license":"Homebrew Playtest","book":""},"uses":{"max":"","spent":0,"recovery":[]},"type":{"value":"monster","subtype":""},"requirements":"","activities":{},"identifier":"incorporeal-movement"},"effects":[],"flags":{},"sort":200000,"ownership":{"default":0},"_key":"!actors.items!hxbSpecterActor1.hxbIncorporeal01"},{"_id":"hxbSunlight00001","name":"Sunlight Sensitivity","type":"feat","img":"icons/magic/light/explosion-star-glow-yellow.webp","system":{"description":{"value":"<p>While in sunlight and outside the summoner's Hex Aura, the specter has Disadvantage on attack rolls and Wisdom (Perception) checks that rely on sight.</p>","chat":""},"source":{"custom":"Soul Blade Patron","rules":"2024","revision":1,"license":"Homebrew Playtest","book":""},"uses":{"max":"","spent":0,"recovery":[]},"type":{"value":"monster","subtype":""},"requirements":"","activities":{},"identifier":"sunlight-sensitivity"},"effects":[],"flags":{},"sort":300000,"ownership":{"default":0},"_key":"!actors.items!hxbSpecterActor1.hxbSunlight00001"}],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"_stats":{"duplicateSource":null,"coreVersion":"14.364","systemId":"dnd5e","systemVersion":"5.3.3","createdTime":1770000000000,"modifiedTime":1770000500000,"lastModifiedBy":"soulbladeplaytest","exportSou