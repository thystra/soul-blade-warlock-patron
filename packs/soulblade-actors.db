{"_id":"hxbSpecterActor1","name":"Hexbound Specter","type":"npc","img":"icons/magic/death/undead-ghost-scream-teal.webp","system":{"abilities":{"str":{"value":1,"proficient":0,"bonuses":{"check":"","save":""}},"dex":{"value":14,"proficient":0,"bonuses":{"check":"","save":""}},"con":{"value":11,"proficient":0,"bonuses":{"check":"","save":""}},"int":{"value":10,"proficient":0,"bonuses":{"check":"","save":""}},"wis":{"value":10,"proficient":0,"bonuses":{"check":"","save":""}},"cha":{"value":18,"proficient":0,"bonuses":{"check":"","save":""}}},"attributes":{"ac":{"flat":13,"calc":"natural","formula":"12 + half the summoner's Proficiency Bonus, rounded down"},"hp":{"value":40,"max":40,"temp":0,"tempmax":0,"formula":"10 + five times the summoning Warlock's level"},"init":{"ability":"","bonus":"","roll":{"mode":0,"min":null,"max":null}},"movement":{"burrow":null,"climb":null,"fly":50,"swim":null,"walk":0,"units":"ft","hover":true},"senses":{"darkvision":60,"blindsight":null,"tremorsense":null,"truesight":null,"units":"ft","special":""},"spellcasting":"","prof":3},"details":{"biography":{"value":"<p>A bound fragment of a departed hostile creature, shaped by a Soul Blade's aura into a spectral ally.</p><p><strong>Scaling:</strong> AC equals 12 + half the summoner's Proficiency Bonus, rounded down. Hit Points equal 10 + five times the summoning Warlock's level. Life Drain attack bonus equals +4 plus the summoner's Charisma modifier. Life Drain deals 3d6 Necrotic damage, increasing to 4d6 at Warlock level 10 and 5d6 at Warlock level 14.</p>","public":""},"alignment":"Neutral","race":"","type":{"value":"undead","subtype":"","swarm":"","custom":""},"environment":"","cr":0,"spellLevel":0,"source":{"custom":"Soul Blade Patron","rules":"2024","revision":1,"license":"Homebrew Playtest","book":""}},"traits":{"size":"med","di":{"value":["necrotic","poison"],"custom":""},"dr":{"value":["acid","cold","fire","lightning","thunder","bludgeoning","piercing","slashing"],"custom":""},"dv":{"value":[],"custom":""},"ci":{"value":["charmed","exhaustion","frightened","grappled","paralyzed","petrified","poisoned","prone","restrained","unconscious"],"custom":""},"languages":{"value":[],"custom":"Understands the languages it knew in life and the languages known by its summoner, but cannot speak."}},"currency":{"pp":0,"gp":0,"ep":0,"sp":0,"cp":0},"skills":{}},"prototypeToken":{"name":"Hexbound Specter","displayName":20,"actorLink":false,"appendNumber":false,"prependAdjective":false,"texture":{"src":"icons/magic/death/undead-ghost-scream-teal.webp","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":"#ffffff","alphaThreshold":0.75},"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"disposition":1,"displayBars":40,"bar1":{"attribute":"attributes.hp"},"bar2":{"attribute":""},"light":{"negative":false,"priority":0,"alpha":0.5,"angle":360,"bright":0,"color":null,"coloration":1,"dim":0,"attenuation":0.5,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"type":null,"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"sight":{"enabled":false,"range":0,"angle":360,"visionMode":"basic","color":null,"attenuation":0.1,"brightness":0,"saturation":0,"contrast":0},"detectionModes":[]},"items":[{"_id":"hxbLifeDrain0001","name":"Life Drain","type":"feat","img":"icons/magic/unholy/hand-claw-glow-orange.webp","system":{"description":{"value":"<p><strong>Life Drain.</strong> Melee Spell Attack: +4 plus the summoner's Charisma modifier to hit, reach 5 feet, one creature.</p>\n<p>Hit: Necrotic damage based on the summoner's Warlock level: 3d6 at level 6, 4d6 at level 10, and 5d6 at level 14.</p>\n<p><strong>Foundry setup:</strong> The activities below use a flat attack formula of <code>4 + @abilities.cha.mod</code>. Set the specter's Charisma modifier to match the summoner's Charisma modifier if the roll does not calculate correctly after summoning.</p>\n<p>Quick manual rolls: [[/attack formula=\"4 + @abilities.cha.mod\"]] [[/damage 3d6 necrotic]] [[/damage 4d6 necrotic]] [[/damage 5d6 necrotic]]</p>","chat":""},"source":{"custom":"Soul Blade Patron","rules":"2024","revision":1,"license":"Homebrew Playtest","book":""},"uses":{"max":"","spent":0,"recovery":[]},"type":{"value":"monster","subtype":""},"requirements":"","activities":{"hxbLD3d6":{"_id":"hxbLD3d6","type":"attack","activation":{"type":"action","value":1,"condition":"","override":false},"attack":{"ability":"","bonus":"4 + @abilities.cha.mod","critical":{"threshold":null},"flat":true,"type":{"value":"melee","classification":"spell"}},"consumption":{"targets":[],"scaling":{"allowed":false,"max":""},"spellSlot":false},"damage":{"critical":{"bonus":""},"includeBase":false,"parts":[{"number":3,"denomination":6,"bonus":"","types":["necrotic"],"custom":{"enabled":false,"formula":""},"scaling":{"mode":"","number":null,"formula":""}}]},"description":{"chatFlavor":"Life Drain (3d6): melee spell attack, +4 plus the summoner's Charisma modifier to hit."},"duration":{"concentration":false,"value":"","units":"inst","special":"","override":false},"effects":[],"range":{"value":5,"units":"ft","special":"","override":false},"target":{"template":{"count":"","contiguous":false,"type":"","size":"","width":"","height":"","units":""},"affects":{"count":"1","type":"creature","choice":false,"special":""},"prompt":true,"override":false},"uses":{"spent":0,"recovery":[],"max":""},"sort":0,"name":"Life Drain (3d6)","img":"icons/magic/unholy/hand-claw-glow-orange.webp","appliedEffects":[],"enchant":{},"visibility":{"level":{"min":null,"max":null}}},"hxbLD4d6":{"_id":"hxbLD4d6","type":"attack","activation":{"type":"action","value":1,"condition":"","override":false},"attack":{"ability":"","bonus":"4 + @abilities.cha.mod","critical":{"threshold":null},"flat":true,"type":{"value":"melee","classification":"spell"}},"consumption":{"targets":[],"scaling":{"allowed":false,"max":""},"spellSlot":false},"damage":{"critical":{"bonus":""},"includeBase":false,"