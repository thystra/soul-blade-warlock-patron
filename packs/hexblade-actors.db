{"_id":"hxbSpecterActor1","name":"Hexbound Specter","type":"npc","img":"icons/magic/death/undead-ghost-scream-teal.webp","system":{"abilities":{"str":{"value":1,"proficient":0,"bonuses":{"check":"","save":""}},"dex":{"value":14,"proficient":0,"bonuses":{"check":"","save":""}},"con":{"value":11,"proficient":0,"bonuses":{"check":"","save":""}},"int":{"value":10,"proficient":0,"bonuses":{"check":"","save":""}},"wis":{"value":10,"proficient":0,"bonuses":{"check":"","save":""}},"cha":{"value":11,"proficient":0,"bonuses":{"check":"","save":""}}},"attributes":{"ac":{"flat":13,"calc":"natural","formula":"12 + half the summoner's Proficiency Bonus, rounded down"},"hp":{"value":40,"max":40,"temp":0,"tempmax":0,"formula":"10 + five times the summoning Warlock's level"},"init":{"ability":"","bonus":"","roll":{"mode":0,"min":null,"max":null}},"movement":{"burrow":null,"climb":null,"fly":50,"swim":null,"walk":0,"units":"ft","hover":true},"senses":{"darkvision":60,"blindsight":null,"tremorsense":null,"truesight":null,"units":"ft","special":""},"spellcasting":"","prof":3},"details":{"biography":{"value":"<p>A bound fragment of a departed hostile creature, shaped by a Hexblade's aura into a spectral ally.</p><p><strong>Scaling:</strong> AC equals 12 + half the summoner's Proficiency Bonus, rounded down. Hit Points equal 10 + five times the summoning Warlock's level. Life Drain attack bonus equals +4 plus the summoner's Charisma modifier. Life Drain deals 3d6 Necrotic damage, increasing to 4d6 at Warlock level 10 and 5d6 at Warlock level 14.</p>","public":""},"alignment":"Neutral","race":"","type":{"value":"undead","subtype":"","swarm":"","custom":""},"environment":"","cr":0,"spellLevel":0,"source":{"custom":"Hexblade Patron Playtest","rules":"2024","revision":1,"license":"Homebrew Playtest","book":""}},"traits":{"size":"med","di":{"value":["necrotic","poison"],"custom":""},"dr":{"value":["acid","cold","fire","lightning","thunder","bludgeoning","piercing","slashing"],"custom":""},"dv":{"value":[],"custom":""},"ci":{"value":["charmed","exhaustion","frightened","grappled","paralyzed","petrified","poisoned","prone","restrained","unconscious"],"custom":""},"languages":{"value":[],"custom":"Understands the languages it knew in life and the languages known by its summoner, but cannot speak."}},"currency":{"pp":0,"gp":0,"ep":0,"sp":0,"cp":0},"skills":{}},"prototypeToken":{"name":"Hexbound Specter","displayName":20,"actorLink":false,"appendNumber":false,"prependAdjective":false,"texture":{"src":"icons/magic/death/undead-ghost-scream-teal.webp","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":"#ffffff","alphaThreshold":0.75},"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"disposition":1,"displayBars":40,"bar1":{"attribute":"attributes.hp"},"bar2":{"attribute":""},"light":{"negative":false,"priority":0,"alpha":0.5,"angle":360,"bright":0,"color":null,"coloration":1,"dim":0,"attenuation":0.5,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"type":null,"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"sight":{"enabled":false,"range":0,"angle":360,"visionMode":"basic","color":null,"attenuation":0.1,"brightness":0,"saturation":0,"contrast":0},"detectionModes":[]},"items":[{"_id":"hxbLifeDrain0001","name":"Life Drain","type":"feat","img":"icons/magic/unholy/hand-claw-glow-orange.webp","system":{"description":{"value":"<p><strong>Life Drain.</strong> Melee Spell Attack: +4 plus the summoner's Charisma modifier to hit, reach 5 feet, one creature. Hit: 3d6 Necrotic damage.</p><p>The damage increases to 4d6 when the summoner reaches Warlock level 10 and 5d6 when the summoner reaches Warlock level 14.</p><p><strong>Foundry use:</strong> This baseline actor does not know the summoner's Charisma modifier. Roll the attack manually using +4 + the summoner's Charisma modifier, and roll the appropriate damage by Warlock level.</p>","chat":""},"source":{"custom":"Hexblade Patron Playtest","rules":"2024","revision":1,"license":"Homebrew Playtest","book":""},"uses":{"max":"","spent":0,"recovery":[]},"type":{"value":"monster","subtype":""},"requirements":"","activities":{},"identifier":"life-drain"},"effects":[],"flags":{},"sort":100000,"ownership":{"default":0},"_key":"!actors.items!hxbSpecterActor1.hxbLifeDrain0001"},{"_id":"hxbIncorporeal01","name":"Incorporeal Movement","type":"feat","img":"icons/magic/movement/trail-streak-zigzag-yellow.webp","system":{"description":{"value":"<p>The specter can move through creatures and objects as if they were Difficult Terrain. It takes 1d10 Force damage if it ends its turn inside an object.</p>","chat":""},"source":{"custom":"Hexblade Patron Playtest","rules":"2024","revision":1,"license":"Homebrew Playtest","book":""},"uses":{"max":"","spent":0,"recovery":[]},"type":{"value":"monster","subtype":""},"requirements":"","activities":{},"identifier":"incorporeal-movement"},"effects":[],"flags":{},"sort":200000,"ownership":{"default":0},"_key":"!actors.items!hxbSpecterActor1.hxbIncorporeal01"},{"_id":"hxbSunlight00001","name":"Sunlight Sensitivity","type":"feat","img":"icons/magic/light/explosion-star-glow-yellow.webp","system":{"description":{"value":"<p>While in sunlight and outside the summoner's Hex Aura, the specter has Disadvantage on attack rolls and Wisdom (Perception) checks that rely on sight.</p>","chat":""},"source":{"custom":"Hexblade Patron Playtest","rules":"2024","revision":1,"license":"Homebrew Playtest","book":""},"uses":{"max":"","spent":0,"recovery":[]},"type":{"value":"monster","subtype":""},"requirements":"","activities":{},"identifier":"sunlight-sensitivity"},"effects":[],"flags":{},"sort":300000,"ownership":{"default":0},"_key":"!actors.items!hxbSpecterActor1.hxbSunlight00001"}],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"_stats":{"duplicateSource":null,"coreVersion":"14.364","systemId":"dnd5e","systemVersion":"5.3.3","createdTime":1770000000000,"modifiedTime":1770000400000,"lastModifiedBy":"hexbladeplaytest","exportSource":null},"_key":"!actors!hxbSpecterActor1"}
